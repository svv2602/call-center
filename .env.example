# =============================================================================
# Call Center AI — Environment Variables
# =============================================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local
# Load:
#   set -a; . ./.env.local; set +a
# =============================================================================

# --- Asterisk AudioSocket ---
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=9092

# --- Google Cloud ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json
GOOGLE_STT_LANGUAGE_CODE=uk-UA
GOOGLE_STT_ALTERNATIVE_LANGUAGES=ru-RU
GOOGLE_TTS_VOICE=uk-UA-Wavenet-A
GOOGLE_TTS_SPEAKING_RATE=0.93
GOOGLE_TTS_PITCH=-1.0

# --- Claude API (Anthropic) --- REQUIRED
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- OpenAI (embeddings for knowledge base) ---
# Used by knowledge base RAG search. Optional — system works without it.
# Using OpenAI text-embedding-3-small for best multilingual quality.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# --- Store API --- REQUIRED
STORE_API_URL=http://localhost:3000/api/v1
STORE_API_KEY=your-store-api-key
STORE_API_TIMEOUT=5

# --- 1C API (real backend for MVP: search_tires, check_availability) ---
ONEC_URL=http://192.168.11.9
ONEC_USERNAME=your-1c-username
ONEC_PASSWORD=your-1c-password
ONEC_TIMEOUT=10
ONEC_SYNC_INTERVAL_MINUTES=5
ONEC_STOCK_CACHE_TTL=300

# --- PostgreSQL --- REQUIRED
DATABASE_URL=postgresql+asyncpg://callcenter:callcenter_dev_pass@localhost:5432/callcenter_dev
POSTGRES_PASSWORD=your-postgres-password

# --- Redis --- REQUIRED
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_SESSION_TTL=1800

# --- Admin --- REQUIRED (in production, fail-fast on defaults)
ADMIN_JWT_SECRET=your-jwt-secret
ADMIN_PASSWORD=your-admin-password

# --- Grafana --- REQUIRED (in production)
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# --- Flower --- REQUIRED (in production)
FLOWER_BASIC_AUTH=user:password

# --- Asterisk ARI ---
ARI_URL=http://localhost:8088/ari
ARI_USER=your-ari-user
ARI_PASSWORD=your-ari-password

# --- DeepSeek API (LLM routing, optional) ---
# DEEPSEEK_API_KEY=sk-...

# --- Gemini API (LLM routing, optional) ---
# GEMINI_API_KEY=AI...

# --- Internal API (Asterisk -> Call Processor) ---
INTERNAL_API_SECRET=your-internal-api-secret

# --- Metrics (Prometheus scraper auth) ---
METRICS_BEARER_TOKEN=your-metrics-bearer-token

# --- Feature Flags ---
FF_LLM_ROUTING_ENABLED=false

# --- Alertmanager (Telegram alerts) ---
ALERTMANAGER_TELEGRAM_BOT_TOKEN=your-bot-token
ALERTMANAGER_TELEGRAM_CHAT_ID=123456789

# --- Monitoring ---
PROMETHEUS_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
